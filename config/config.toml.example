[threads]
app_id = "YOUR_APP_ID"
app_secret_file = "~/.config/threads-cli/app_secret"
redirect_uri = "http://127.0.0.1:8788/callback"
user_id = "YOUR_THREADS_USER_ID"
base_url = "https://graph.threads.net"
version = "v1.0"

[storage]
database_path = "~/.local/share/threads-cli/threads.db"

[defaults]
link_mode = "reply"
output = "human"
open_browser = true

[oauth]
listen_host = "127.0.0.1"
listen_port = 8788
state_ttl_seconds = 600
